# Web: copy values into apps/web/.env.local (ignored by git), or run:
#   npm run env:ingest   (from repo root — validates URL + anon key, then writes apps/web/.env.local)
#
# Vite / Netlify web app (browser-safe with RLS)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile — public site key only in the client (not the secret)
# VITE_TURNSTILE_SITE_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Edge Functions (server-only; Supabase injects in production — never put in Vite/Netlify client)
# SUPABASE_SERVICE_ROLE_KEY=

# get-volunteer-command-metrics: comma-separated manager emails (lowercase recommended). Server-only secret config.
# VOLUNTEER_COMMAND_METRICS_ADMIN_EMAILS=manager@example.com

# Optional: salt for hashing client IPs in intake rate-limit table (create-volunteer-from-intake)
# INTAKE_RATE_SALT=

# Cloudflare Turnstile secret — Edge only (Supabase secrets / dashboard), never in Vite
# TURNSTILE_SECRET_KEY=

# Intake rate-limit bypass: send header X-Campos-Intake-Rate-Override with this exact value (server tools only; min 32 chars)
# INTAKE_RATE_OVERRIDE_SECRET=

# AI / LLM
OPENAI_API_KEY=

# Messaging / Email
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Data providers
CENSUS_API_KEY=
BLS_API_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

